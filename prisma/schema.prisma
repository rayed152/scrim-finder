generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String       @id @default(cuid())
  name            String
  email           String       @unique
  passwordHash    String
  valorantTag     String?
  rank            Int?
  preferredServer String?
  discordId       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  createdTeams    Team[]       @relation("TeamCaptain")
  teamMembers     TeamMember[]
}

model Team {
  id             String       @id @default(cuid())
  name           String       @unique
  captainId      String
  captain        User         @relation("TeamCaptain", fields: [captainId], references: [id])
  server         String
  isQueued       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  members        TeamMember[]
  queueEntry     QueueEntry?
  matchesAsTeam1 Match[]      @relation("MatchTeam1")
  matchesAsTeam2 Match[]      @relation("MatchTeam2")
}

model TeamMember {
  id       String   @id @default(cuid())
  userId   String   @unique
  teamId   String
  user     User     @relation(fields: [userId], references: [id])
  team     Team     @relation(fields: [teamId], references: [id])
  joinedAt DateTime @default(now())

  @@unique([userId, teamId])
}

model QueueEntry {
  id           String   @id @default(cuid())
  teamId       String   @unique
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  avgRankScore Float
  server       String
  queuedAt     DateTime @default(now())
  status       String   @default("searching")
}

model Match {
  id             String   @id @default(cuid())
  team1Id        String
  team2Id        String
  team1          Team     @relation("MatchTeam1", fields: [team1Id], references: [id])
  team2          Team     @relation("MatchTeam2", fields: [team2Id], references: [id])
  server         String
  rankDifference Float
  status         String   @default("pending")
  createdAt      DateTime @default(now())
}